{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Read",
      "Edit",
      "Write"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "변경 파일 포맷 중...",
            "command": "python3 .agent-harness/hooks/format_changed_file.py"
          },
          {
            "type": "command",
            "statusMessage": "사용 가능한 테스트 실행 중...",
            "command": "python3 .agent-harness/hooks/run_tests.py"
          },
          {
            "type": "command",
            "statusMessage": "TDD 대응 테스트 확인 중...",
            "command": "python3 .agent-harness/hooks/tdd_guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"범용 에이전트 하네스 종료 훅 완료.\"}'"
          }
        ]
      }
    ]
  }
}
