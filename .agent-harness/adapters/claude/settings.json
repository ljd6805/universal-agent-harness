{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Read",
      "Edit",
      "Write"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Formatting changed file...",
            "command": "python3 .agent-harness/hooks/format_changed_file.py"
          },
          {
            "type": "command",
            "statusMessage": "Running available tests...",
            "command": "python3 .agent-harness/hooks/run_tests.py"
          },
          {
            "type": "command",
            "statusMessage": "Checking TDD coverage...",
            "command": "python3 .agent-harness/hooks/tdd_guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Universal Agent Harness stop hook complete.\"}'"
          }
        ]
      }
    ]
  }
}
